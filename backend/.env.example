# Backend environment variables
# Copy to .env and fill in your values.

# ElevenLabs API key (optional — falls back to Kokoro TTS if not set)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Whisper model size: base | small | medium
WHISPER_MODEL_SIZE=base

# Comma-separated allowed browser origins (include your frontend URL)
ECHO_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Database path (default: echo.db in project root)
DATABASE_URL=sqlite:///app/echo.db